{
  "name": "foundation-health-take-home",
  "version": "1.0.0",
  "description": "HTTP API that counts MPEG-1 Audio Layer III frames in an uploaded MP3 file.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docker:build": "docker build -t mp3-frame-counter .",
    "docker:run": "docker run --rm -p 3000:3000 mp3-frame-counter"
  },
  "dependencies": {
    "@fastify/multipart": "^10.0.0",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "form-data": "^4.0.6",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
